# Optional: Override the site URL for deployments
# GitHub Pages default: https://okikio.github.io
# Cloudflare Pages example: https://your-project.pages.dev
# SITE_URL=https://your-domain.com

# Optional: Override the base path for the site
# Default: /  (works for Cloudflare Pages and most root deployments)
# GitHub Pages: set automatically by actions/configure-pages (e.g. /pstream-docs)
# BASE_PATH=/mov-docs
